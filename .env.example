# QNA Pipeline Environment Variables Template
# Copy this file to '.env' and fill in your API credentials.

# --- Analysis LLM Configuration ---
# The pipeline falls back to these environment variables when configuring the LLM analysis mode.

# Option 1: OpenAI-compatible API (e.g., Kimi, DeepSeek, local OpenAI)
KIMI_API_KEY=sk-...
KIMI_BASE_URL=https://api.sfkey.cn/v1
KIMI_MODEL=kimi-k2.6

# Option 2: Standard OpenAI API credentials
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Option 3: Explicit Pipeline Analysis Environment Variables
# These have the highest priority fallback in the codebase
ANALYSIS_LLM_API_KEY=sk-...
ANALYSIS_LLM_BASE_URL=https://api.openai.com/v1
ANALYSIS_LLM_MODEL=gpt-4o

# --- Auxiliary configurations (timeouts & streaming settings) ---
API_TIMEOUT_MS=180000
STREAM_DEFAULT=false
